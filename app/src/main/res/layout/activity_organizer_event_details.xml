<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/white"
    tools:context=".OrganizerEventDetailsActivity">

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:padding="24dp"
        android:layout_marginBottom="56dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

            <!-- Back + Screen Title -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <ImageView
                    android:id="@+id/iv_back"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:src="@android:drawable/ic_menu_revert"
                    android:contentDescription="Back" />

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Event Info"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark"
                    android:gravity="center" />
            </LinearLayout>

            <!-- Enable Geolocation toggle -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="8dp">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="Enable Geolocation Requirement"
                    android:textSize="13sp"
                    android:textColor="@color/text_dark" />

                <com.google.android.material.switchmaterial.SwitchMaterial
                    android:id="@+id/switch_geolocation"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content" />
            </LinearLayout>

            <!-- Event Header Row -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginTop="16dp">

                <ImageView
                    android:id="@+id/iv_organizer_avatar"
                    android:layout_width="40dp"
                    android:layout_height="40dp"
                    android:src="@android:drawable/ic_menu_myplaces"
                    android:contentDescription="Organizer avatar" />

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:orientation="vertical"
                    android:layout_marginStart="8dp">

                    <TextView
                        android:id="@+id/tv_event_name"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Event 1"
                        android:textSize="15sp"
                        android:textStyle="bold"
                        android:textColor="@color/text_dark" />

                    <TextView
                        android:id="@+id/tv_event_location"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Edmonton"
                        android:textSize="13sp"
                        android:textColor="@color/text_muted" />
                </LinearLayout>

                <Button
                    android:id="@+id/btn_show_qr"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Show QR Code"
                    android:textSize="11sp" />
            </LinearLayout>

            <!-- Poster placeholder -->
            <FrameLayout
                android:id="@+id/fl_event_poster"
                android:layout_width="match_parent"
                android:layout_height="120dp"
                android:layout_marginTop="16dp"
                android:background="@color/bg_light">

                <ImageView
                    android:layout_width="60dp"
                    android:layout_height="60dp"
                    android:layout_gravity="center"
                    android:src="@android:drawable/ic_menu_gallery"
                    android:contentDescription="Event poster placeholder" />
            </FrameLayout>

            <!-- Event details -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp">

                <TextView
                    android:id="@+id/tv_event_name_detail"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_alignParentTop="true"
                    android:text="Event name"
                    android:textSize="18sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_dark" />

                <TextView
                    android:id="@+id/tv_event_dates"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_alignBaseline="@id/tv_event_name_detail"
                    android:text="02/02/2026 - 20/03/2026"
                    android:textSize="14sp"
                    android:textColor="@color/text_muted" />

                <TextView
                    android:id="@+id/tv_organizer_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_below="@id/tv_event_name_detail"
                    android:layout_marginTop="4dp"
                    android:text="Organizer 1"
                    android:textSize="14sp"
                    android:textColor="@color/text_muted" />

                <TextView
                    android:id="@+id/tv_waitlist_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_alignBaseline="@id/tv_organizer_label"
                    android:text="Waitlist: 50/100"
                    android:textSize="14sp"
                    android:textColor="@color/text_muted" />

                <TextView
                    android:id="@+id/tv_capacity_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentStart="true"
                    android:layout_below="@id/tv_organizer_label"
                    android:layout_marginTop="4dp"
                    android:text="Capacity: 100"
                    android:textSize="14sp"
                    android:textColor="@color/text_muted" />

                <TextView
                    android:id="@+id/tv_event_visibility"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:layout_alignParentEnd="true"
                    android:layout_below="@id/tv_waitlist_label"
                    android:layout_marginTop="4dp"
                    android:text="Visibility: Public"
                    android:textSize="14sp"
                    android:textColor="@color/text_muted" />

                <TextView
                    android:id="@+id/tv_event_description"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:layout_below="@id/tv_event_visibility"
                    android:layout_marginTop="8dp"
                    android:text="Text detail of the event\nOther details of the event\n \u2022 Result is picked by organizer"
                    android:textSize="14sp"
                    android:textColor="@color/text_muted"
                    android:lineSpacingExtra="4dp" />
            </RelativeLayout>

            <!-- Action buttons matching mockup -->
            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="20dp"
                android:layout_marginBottom="16dp">

                <Button
                    android:id="@+id/btn_edit_event"
                    android:layout_width="140dp"
                    android:layout_height="wrap_content"
                    android:minHeight="44dp"
                    android:layout_alignParentStart="true"
                    android:layout_alignParentTop="true"
                    android:backgroundTint="#65559F"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    android:text="Edit the Event" />

                <Button
                    android:id="@+id/btn_view_waitlist"
                    android:layout_width="140dp"
                    android:layout_height="wrap_content"
                    android:minHeight="44dp"
                    android:layout_alignParentEnd="true"
                    android:layout_alignParentTop="true"
                    android:backgroundTint="#65559F"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    android:text="View the Waitlist" />

                <Button
                    android:id="@+id/btn_registration_map"
                    android:layout_width="140dp"
                    android:layout_height="wrap_content"
                    android:minHeight="44dp"
                    android:layout_below="@id/btn_view_waitlist"
                    android:layout_alignParentEnd="true"
                    android:layout_marginTop="16dp"
                    android:backgroundTint="#65559F"
                    android:textColor="@color/white"
                    android:textSize="12sp"
                    android:textAllCaps="false"
                    android:text="Registration Map" />

            </RelativeLayout>
        </LinearLayout>
    </androidx.core.widget.NestedScrollView>

    <!-- Bottom Navigation -->
    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:menu="@menu/organizer_bottom_nav" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
