<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2ECF6"
    tools:context=".OrganizerEntrantListActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="80dp"
        android:orientation="vertical"
        android:paddingHorizontal="14dp"
        android:paddingTop="18dp"
        android:paddingBottom="12dp">

        <ImageButton
            android:id="@+id/btn_back"
            android:layout_width="36dp"
            android:layout_height="36dp"
            android:background="@android:color/transparent"
            android:contentDescription="Back"
            android:padding="6dp"
            android:src="@drawable/ic_back"
            app:tint="@color/text_dark" />

        <androidx.appcompat.widget.SearchView
            android:id="@+id/sv_search_entrant"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_search_bar"
            android:iconifiedByDefault="false"
            android:paddingHorizontal="4dp"
            app:queryHint="Search by Entrant Name" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_entrants"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/tv_empty_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingVertical="16dp"
            android:text="No entrants have joined this waiting list yet."
            android:textColor="@color/text_muted"
            android:textSize="15sp"
            android:visibility="gone" />

        <LinearLayout
            android:id="@+id/ll_action_buttons"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:paddingTop="6dp">



            <Button
                android:id="@+id/btn_send_notification_to_all"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="@string/organizer_send_notification_all" />

            <Button
                android:id="@+id/btn_view_lottery_winners"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="View Lottery Winners" />

            <Button
                android:id="@+id/btn_invite_selected_waitlist"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Send invitation to selected for waitlist"
                android:visibility="gone" />

            <Button
                android:id="@+id/btn_assign_selected_coorganizer"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:text="Assign selected as co-organizers"
                android:visibility="gone" />

            <EditText
                android:id="@+id/et_lottery_count"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:hint="Enter number of attendees to draw"
                android:inputType="number" />

            <Button
                android:id="@+id/btn_lottery_draw"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:backgroundTint="@color/outline_gray"
                android:text="lottery Draw"
                android:textColor="@color/text_dark" />

            <Button
                android:id="@+id/btn_redraw_entrants"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:backgroundTint="@color/outline_gray"
                android:text="Redraw Entrants"
                android:textColor="@color/text_dark" />

            <Button
                android:id="@+id/btn_delete_all_selected"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="4dp"
                android:backgroundTint="#DC3545"
                android:text="Delete All Selected Entrants" />

        </LinearLayout>

    </LinearLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:menu="@menu/organizer_bottom_nav" />

</androidx.coordinatorlayout.widget.CoordinatorLayout>
