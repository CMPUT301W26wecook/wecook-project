<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginVertical="6dp"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <CheckBox
        android:id="@+id/cb_waitlist_selected"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:buttonTint="#6E57B4"
        android:paddingEnd="4dp" />

    <LinearLayout
        android:id="@+id/layout_row_content"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_weight="1"
        android:orientation="vertical">

        <LinearLayout
            android:id="@+id/layout_row_main"
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:background="@drawable/bg_selection_row"
            android:gravity="center_vertical"
            android:orientation="horizontal"
            android:paddingHorizontal="12dp">

            <TextView
                android:id="@+id/tv_entrant_name"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Entrant"
                android:textColor="#3F3B49"
                android:textSize="16sp"
                android:textStyle="normal" />

            <ImageButton
                android:id="@+id/btn_item_menu"
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:background="@android:color/transparent"
                android:contentDescription="More options"
                android:padding="3dp"
                android:src="@android:drawable/ic_menu_more"
                android:tint="#59585E" />
        </LinearLayout>

        <TextView
            android:id="@+id/tv_delete_action"
            android:layout_width="110dp"
            android:layout_height="42dp"
            android:layout_gravity="end"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_selection_delete_action"
            android:gravity="center"
            android:text="Delete"
            android:textColor="#5A4646"
            android:textSize="18sp"
            android:visibility="gone" />
    </LinearLayout>
</LinearLayout>
