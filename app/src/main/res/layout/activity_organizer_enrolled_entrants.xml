<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#F2ECF6"
    tools:context=".OrganizerEnrolledEntrantsActivity">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:layout_marginBottom="72dp"
        android:orientation="vertical"
        android:paddingHorizontal="14dp"
        android:paddingTop="18dp">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="6dp"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <ImageButton
                android:id="@+id/btn_back"
                android:layout_width="36dp"
                android:layout_height="36dp"
                android:background="@android:color/transparent"
                android:contentDescription="Back"
                android:padding="6dp"
                android:src="@drawable/ic_back"
                app:tint="@color/text_dark" />

            <Space
                android:layout_width="0dp"
                android:layout_height="1dp"
                android:layout_weight="1" />

            <Button
                android:id="@+id/btn_export_csv"
                android:layout_width="wrap_content"
                android:layout_height="60dp"
                android:minWidth="72dp"
                android:paddingStart="12dp"
                android:paddingEnd="12dp"
                android:text="@string/export_csv"
                android:textAllCaps="false"
                android:textColor="@android:color/white"
                android:textSize="14sp"
                android:backgroundTint="#2196F3" />
        </LinearLayout>

        <androidx.appcompat.widget.SearchView
            android:id="@+id/sv_search_entrant"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="6dp"
            android:background="@drawable/bg_search_bar"
            android:iconifiedByDefault="false"
            android:paddingHorizontal="4dp"
            app:queryHint="Search by name, phone, or email" />

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rv_entrants"
            android:layout_width="match_parent"
            android:layout_height="0dp"
            android:layout_marginTop="12dp"
            android:layout_weight="1"
            android:clipToPadding="false"
            android:paddingBottom="8dp" />

        <TextView
            android:id="@+id/tv_empty_state"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:gravity="center"
            android:paddingVertical="16dp"
            android:text="No enrolled entrants yet."
            android:textColor="@color/text_muted"
            android:textSize="15sp"
            android:visibility="gone" />
    </LinearLayout>

    <com.google.android.material.bottomnavigation.BottomNavigationView
        android:id="@+id/bottom_nav"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        app:menu="@menu/organizer_bottom_nav" />
</androidx.coordinatorlayout.widget.CoordinatorLayout>
